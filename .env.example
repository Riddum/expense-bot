# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Web App Dashboard URL
WEBAPP_URL=https://your-webapp-url.netlify.app

# Port (Render sets this automatically, but can override)
PORT=5000

# Database path
LEDGER_DB_PATH=ledger.db

# Google Sheets Integration (optional)
# Set either:
# 1. GOOGLE_SERVICE_ACCOUNT_JSON with the full JSON as a string
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'
# OR
# 2. GOOGLE_APPLICATION_CREDENTIALS pointing to service account file
GOOGLE_APPLICATION_CREDENTIALS=service_account.json
